{"instruction": "Tower of Hanoi (count moves)", "input": "4", "output": "15", "whisper": ": hanoi { _ 1 = ?? drop 1 | _ 1 - hanoi 2 * 1 + ] } ;\n4 hanoi .", "python": "def hanoi(n):\n    if n == 1: return 1\n    return 2 * hanoi(n-1) + 1\nprint(hanoi(4))"}
{"instruction": "Collatz sequence length", "input": "6", "output": "9", "whisper": ": collatz { _ 1 = ?? drop 1 | _ 2 % 0 = ?? 2 / collatz 1 + | _ 3 * 1 + collatz 1 + ] ] } ;\n6 collatz .", "python": "def collatz(n):\n    if n == 1: return 1\n    if n % 2 == 0: return 1 + collatz(n//2)\n    return 1 + collatz(3*n+1)\nprint(collatz(6))"}
{"instruction": "Ackermann function", "input": "2 3", "output": "9", "whisper": ": ack { _ 0 = ?? drop 1 + | over 0 = ?? drop drop 1 - | _ 1 - over ` 1 - ack ` ack ] ] } ;\n2 3 ack .", "python": "def ack(m,n):\n    if m==0: return n+1\n    if n==0: return ack(m-1,1)\n    return ack(m-1, ack(m,n-1))\nprint(ack(2,3))"}
{"instruction": "Fibonacci with memoization (iterative)", "input": "10", "output": "55", "whisper": ": fib-iter {\n  0 1 rot\n  { _ 0 > } { _ over + ` 1 - } #\n  drop\n} ;\n10 fib-iter .", "python": "def fib_iter(n):\n    a, b = 0, 1\n    for _ in range(n): a, b = b, a+b\n    return a\nprint(fib_iter(10))"}
{"instruction": "Sum of digits", "input": "12345", "output": "15", "whisper": ": digit-sum {\n  _ 0 = ?? drop 0\n  | _ 10 % over 10 / digit-sum + ]\n} ;\n12345 digit-sum .", "python": "def digit_sum(n):\n    if n == 0: return 0\n    return n%10 + digit_sum(n//10)\nprint(digit_sum(12345))"}
{"instruction": "Is prime (recursive trial division)", "input": "17", "output": "#t", "whisper": ": prime-check {\n  _ over * over >= ?? drop drop #t\n  | _ over % 0 = ?? drop drop #f\n  | 1 + ` _ ` prime-check ]\n} ;\n: is-prime { _ 2 < ?? drop #f | 2 _ prime-check ] } ;\n17 is-prime .", "python": "def is_prime(n):\n    if n < 2: return False\n    def check(d, n):\n        if d*d > n: return True\n        if n%d == 0: return False\n        return check(d+1, n)\n    return check(2, n)\nprint(is_prime(17))"}
{"instruction": "Binary representation length", "input": "255", "output": "8", "whisper": ": bits { _ 0 = ?? drop 1 | 2 / bits 1 + ] } ;\n255 bits .", "python": "def bits(n):\n    if n == 0: return 1\n    return 1 + bits(n//2)\nprint(bits(255))"}
