{"instruction": "Count digits", "input": "12345", "output": "5", "whisper": ": count-digits { _ 10 < ?? drop 1 | 10 / count-digits 1 + ] } ;\n12345 count-digits .", "python": "def count_digits(n):\n    if n < 10: return 1\n    return 1 + count_digits(n // 10)\nprint(count_digits(12345))"}
{"instruction": "Reverse digits", "input": "12345", "output": "54321", "whisper": ": rev-digits { _ 10 < ?? | _ 10 % ` 10 / rev-digits ` 10 * + ] } ;\n12345 rev-digits .", "python": "def rev_digits(n):\n    if n < 10: return n\n    return (n%10) * (10**(len(str(n))-1)) + rev_digits(n//10)\nprint(rev_digits(12345))"}
